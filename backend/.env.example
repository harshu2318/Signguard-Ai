# ============================================================
# SignGuard AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# Groq API Key — get yours free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face Hub Token — get yours free at https://huggingface.co/settings/tokens
# (Optional fallback if you prefer using Hugging Face over Groq)
HUGGINGFACEHUB_API_TOKEN=your_huggingface_hub_token_here
